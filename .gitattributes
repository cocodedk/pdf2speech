# Auto-detect text files and normalize line endings to LF.
* text=auto eol=lf

# Explicit text files - always normalize to LF.
*.py    text eol=lf
*.sh    text eol=lf
*.md    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.html  text eol=lf
*.css   text eol=lf
*.toml  text eol=lf
*.svg   text eol=lf
*.txt   text eol=lf
*.fish  text eol=lf

# Binary files - never touch line endings.
*.png    binary
*.jpg    binary
*.ico    binary
*.pdf    binary
*.onnx   binary
*.wav    binary
*.mp3    binary
*.mp4    binary
*.zip    binary
*.tar.gz binary
